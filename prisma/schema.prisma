generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          WhatsappSession[]
  activities        Activity[]
  messageLogs       MessageLog[]
  failedMessageLogs FailedMessageLog[]
}

model WhatsappSession {
  id                String             @id @default(uuid())
  sessionId         String             @unique
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber       String
  isActive          Boolean            @default(true)
  isReady           Boolean            @default(false)
  lastQrCode        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activities        Activity[]
  messageLogs       MessageLog[]
  failedMessageLogs FailedMessageLog[]

  @@index([userId])
}

model Activity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     WhatsappSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  type        String   // 'session_created', 'session_deleted', 'message_sent', 'qr_generated', 'login_success'
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

model MessageLog {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     WhatsappSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  phone       String
  messageText String
  sentAt      DateTime         @default(now())

  @@index([userId, sentAt])
}

model FailedMessageLog {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId     String?
  session       WhatsappSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  phone         String
  messageText   String
  failureReason String
  failedAt      DateTime         @default(now())

  @@index([userId, failedAt])
}
